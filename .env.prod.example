DB_URL=mysql://your-prod-host:3306/your-prod-db
DB_USERNAME=your_prod_user
DB_PASSWORD=your_prod_password

DEFAULT_LIMIT=20
MAX_LIMIT=100

PREMIUM_SONG_TYPE=1
PREMIUM_BOOST_MULTIPLIER=1.2
PREMIUM_MIN_SLOTS=1

HEAVY_USER_EVENT_THRESHOLD=120
LONG_TAIL_BOOST_FOR_HEAVY=1.2
POPULAR_PENALTY_FOR_HEAVY=0.85
LONG_TAIL_MIN_SLOTS_HEAVY=2

APP_LOG_LEVEL=info
APP_TIMEOUT=120
APP_GRACEFUL_TIMEOUT=30
APP_KEEPALIVE=5
APP_WORKERS=2
APP_BIND=0.0.0.0:8000
